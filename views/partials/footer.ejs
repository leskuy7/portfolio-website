<footer>
    <div class="container">
        <p class="mb-0"><%= t('footer') %></p>
    </div>
</footer>

<!-- Scroll to Top Button -->
<button id="scroll-top" class="scroll-top-btn" aria-label="Scroll to top">
    <i class="fas fa-chevron-up"></i>
</button>

<!-- Bootstrap JS — lazy: sadece hamburger ilk tıklandığında yüklenir -->
<script>
(function () {
    var loaded = false;
    function loadBootstrap(cb) {
        if (loaded) { cb && cb(); return; }
        loaded = true;
        var s = document.createElement('script');
        s.src = 'https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js';
        s.onload = function () { cb && cb(); };
        document.head.appendChild(s);
    }
    var toggler = document.querySelector('.navbar-toggler');
    if (toggler) {
        toggler.addEventListener('click', function () { loadBootstrap(); }, { once: true });
    }
    // Idle olunca da yükle, böylece form submit anında zaten hazır
    if ('requestIdleCallback' in window) {
        requestIdleCallback(function () { loadBootstrap(); }, { timeout: 3000 });
    } else {
        setTimeout(loadBootstrap, 2500);
    }
})();
</script>

<!-- Custom JS -->
<script src="/js/main.js" defer></script>